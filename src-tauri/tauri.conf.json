{
  "productName": "codestrux",
  "version": "1.3.2",
  "identifier": "com.code.strux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "codestrux",
        "decorations": false,
        "shadow": true,
        "maximized": true,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:28765 https://huggingface.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/llama-server-vulkan", "bin/llama-server-cpu"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": {
      "bin/*.dll": "./"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      },
      "wix": {
        "bannerPath": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": ""
    },
    "linux": {
      "appimage": {}
    }
  }
}
